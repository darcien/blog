---
import "../styles/global.css";
import { FULL_NAME, SITE_NAME } from "../consts";

type Article = {
  publishedTime: string;
  tags?: string[];
};

type MarkdownLayoutProps = {
  frontmatter: {
    title: string;
    description?: string;
    show_title?: boolean;
    canonical_url?: string;
  };
};

type DirectProps = {
  title: string;
  description?: string;
  showTitle?: boolean;
  /**
   * Override canonical URL for cross-posted content.
   * Defaults to current page URL.
   */
  canonicalUrl?: string;
  /** Set for blog posts to emit article-specific OG meta tags. */
  article?: Article;
};

type Props = MarkdownLayoutProps | DirectProps;

// Markdown pages (about.md, uses.md, etc.) pass props wrapped in `frontmatter`.
// Astro components (index.astro, [slug].astro, etc.) pass props directly.
const { title, description, showTitle, canonicalUrl, article } =
  "frontmatter" in Astro.props
    ? {
        title: Astro.props.frontmatter.title,
        description: Astro.props.frontmatter.description,
        showTitle: Astro.props.frontmatter.show_title ?? true,
        canonicalUrl: Astro.props.frontmatter.canonical_url,
        article: undefined as Article | undefined,
      }
    : {
        title: Astro.props.title,
        description: Astro.props.description,
        showTitle: Astro.props.showTitle ?? false,
        canonicalUrl: Astro.props.canonicalUrl,
        article: Astro.props.article,
      };

if (!Astro.site) {
  throw new Error("site must be set in astro.config.mjs");
}
const SITE_URL = Astro.site.origin;
const isHome = Astro.url.pathname === "/";
const pageTitle = isHome ? title : `${title} | ${FULL_NAME}`;
const canonical = canonicalUrl ?? `${SITE_URL}${Astro.url.pathname}`;
const ogType = article ? "article" : "website";

const navLinks = [
  { name: "posts", url: "/" },
  { name: "now", url: "/now" },
  { name: "about", url: "/about" },
  { name: "uses", url: "/uses" },
  { name: "tags", url: "/tags" },
  { name: "search", url: "/search" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />

    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:locale" content="en" />
    <meta property="og:type" content={ogType} />
    {
      article && (
        <meta
          property="article:published_time"
          content={article.publishedTime}
        />
      )
    }
    {article?.tags?.map((tag) => <meta property="article:tag" content={tag} />)}

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}

    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/apple-touch-icon.png?v=2"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/favicon-32x32.png?v=2"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/favicon-16x16.png?v=2"
    />
    <link rel="manifest" href="/site.webmanifest?v=2" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg?v=2" color="#34343c" />
    <meta name="msapplication-TileColor" content="#da532c" />
    <meta name="theme-color" content="#1a1a1a" />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="site-title">
        <img
          src="/whale_goth.svg"
          alt=""
          class="site-logo"
          width="28"
          height="28"
        />
        {FULL_NAME}
      </a>
      <nav>
        {
          navLinks.map((link) => (
            <a href={link.url} class="nav-link">
              [{link.name}]
            </a>
          ))
        }
      </nav>
    </header>
    <main data-pagefind-body>
      {showTitle && <h1>{title}</h1>}
      <slot />
    </main>
    <slot name="after-main" />
    <footer class="site-footer">
      <span>&copy; {new Date().getFullYear()} {FULL_NAME}</span>
      <div class="footer-blank">This space intentionally left blank.</div>
    </footer>
  </body>
</html>
