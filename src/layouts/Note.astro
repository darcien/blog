---
import Base from "./Base.astro";

type Props = {
  frontmatter: {
    title: string;
    description?: string;
    created: string;
    updated?: string;
    show_toc?: boolean;
    canonical_url?: string;
  };
  headings: { depth: number; slug: string; text: string }[];
};

const { frontmatter, headings } = Astro.props;
const created = new Date(frontmatter.created);
const updated = frontmatter.updated ? new Date(frontmatter.updated) : undefined;
const showToc = frontmatter.show_toc && headings.length > 0;
---

<Base
  title={frontmatter.title}
  description={frontmatter.description}
  canonicalUrl={frontmatter.canonical_url}
  article={{
    publishedTime: created.toISOString(),
  }}
>
  <article>
    <header class="post-header">
      <h1>{frontmatter.title}</h1>
      <time datetime={created.toISOString()}>
        {created.toISOString().slice(0, 10)}
      </time>
      {
        updated && (
          <time datetime={updated.toISOString()}>
            updated {updated.toISOString().slice(0, 10)}
          </time>
        )
      }
    </header>
    {
      showToc && (
        <nav class="toc">
          <details open>
            <summary>Table of contents</summary>
            <ul>
              {headings
                .filter((h) => h.depth <= 3)
                .map((h) => (
                  <li>
                    <span
                      class={
                        h.depth === 2 ? "toc-marker" : "toc-marker toc-nested"
                      }
                    >
                      {h.depth === 2 ? "»" : "›"}
                    </span>
                    <a href={`#${h.slug}`}>{h.text}</a>
                  </li>
                ))}
            </ul>
          </details>
        </nav>
      )
    }
    <slot />
  </article>
</Base>
