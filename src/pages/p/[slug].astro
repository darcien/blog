---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = (
    await getCollection("posts", ({ data }) =>
      import.meta.env.PROD ? data.draft !== true : true,
    )
  ).toSorted((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: posts[i + 1],
      next: posts[i - 1],
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content, headings } = await render(post);
const showToc = post.data.show_toc && headings.length > 0;
---

<Base
  title={post.data.title}
  description={post.data.summary ?? post.data.description}
  canonicalUrl={post.data.canonical_url}
  article={{
    publishedTime: post.data.date.toISOString(),
    tags: post.data.tags,
  }}
>
  <article>
    <header class="post-header">
      <h1>{post.data.title}</h1>
      <time datetime={post.data.date.toISOString()}>
        {post.data.date.toISOString().slice(0, 10)}
      </time>
      {
        post.data.tags && (
          <div class="post-tags">
            {post.data.tags.map((tag) => (
              <a href={`/tags/${tag.toLowerCase()}`}>#{tag}</a>
            ))}
          </div>
        )
      }
    </header>
    {
      showToc && (
        <nav class="toc">
          <details open>
            <summary>Table of contents</summary>
            <ul>
              {headings
                .filter((h) => h.depth <= 3)
                .map((h) => (
                  <li>
                    <span
                      class={
                        h.depth === 2 ? "toc-marker" : "toc-marker toc-nested"
                      }
                    >
                      {h.depth === 2 ? "»" : "›"}
                    </span>
                    <a href={`#${h.slug}`}>{h.text}</a>
                  </li>
                ))}
            </ul>
          </details>
        </nav>
      )
    }
    <Content />
  </article>
  <nav class="post-nav" slot="after-main">
    {prev && <a href={`/p/${prev.id}`}>&larr; {prev.data.title}</a>}
    {
      next && (
        <a class="post-nav-next" href={`/p/${next.id}`}>
          {next.data.title} &rarr;
        </a>
      )
    }
  </nav>
</Base>
