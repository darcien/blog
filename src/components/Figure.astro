---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: string | ImageMetadata;
  alt?: string;
  caption?: string;
  resize?: string;
}

const { src, alt, caption } = Astro.props;
const altText = alt ?? caption ?? "";
const isImported = typeof src !== "string";
---

<figure>
  {
    isImported ? (
      <Image src={src} alt={altText} loading="lazy" />
    ) : (
      <img loading="lazy" src={src} alt={altText} />
    )
  }
  {
    caption && (
      <figcaption>
        <p set:html={caption} />
      </figcaption>
    )
  }
</figure>
<script>
  // @ts-ignore
  import Lightense from "lightense-images";
  Lightense("img:not(.site-logo)", {
    background: "color-mix(in srgb, var(--bg) 90%, transparent)",
    padding: 16,
  });
</script>
