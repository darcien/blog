---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });

  const tagMap = posts
    .flatMap((post) =>
      (post.data.tags ?? []).map((tag) => ({
        slug: tag.toLowerCase(),
        display: tag,
        post,
      })),
    )
    .reduce((acc, { slug, display, post }) => {
      const existing = acc.get(slug);
      if (existing) {
        existing.posts.push(post);
      } else {
        acc.set(slug, { display, posts: [post] });
      }
      return acc;
    }, new Map<string, { display: string; posts: typeof posts }>());

  return [...tagMap.entries()].map(([slug, { display, posts }]) => ({
    params: { tag: slug },
    props: {
      display,
      posts: posts.toSorted(
        (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
      ),
    },
  }));
}

const { tag } = Astro.params;
const { posts, display } = Astro.props;
---

<Base title={`Tag: ${display}`}>
  <div data-pagefind-ignore>
    <h1>Tag: {display}</h1>
    <ul>
      {
        posts.map((post) => (
          <li>
            <a href={`/p/${post.id}/`}>{post.data.title}</a>
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toISOString().slice(0, 10)}
            </time>
          </li>
        ))
      }
    </ul>
  </div>
</Base>
